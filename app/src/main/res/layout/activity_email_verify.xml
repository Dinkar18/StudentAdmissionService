<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieEmail"
        android:layout_width="250dp"
        android:layout_height="250dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/email_verify" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verify Your Email"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvEmailSent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We've sent a verification link to your email. Please check your inbox and click the link."
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginTop="12dp"
        android:alpha="0.7" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckVerification"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="I've Verified My Email"
        android:layout_marginTop="32dp"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResendEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Resend Email"
        android:layout_marginTop="12dp"
        style="@style/Widget.Material3.Button.TextButton"
        app:cornerRadius="12dp" />

</LinearLayout>
