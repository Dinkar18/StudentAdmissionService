<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Documents"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload all required documents for admission"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <!-- 10th Marksheet -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/doc10thMarksheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- 12th Marksheet -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/doc12thMarksheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Aadhaar Card -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docAadhaar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Income Certificate -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docIncome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Caste Certificate -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docCaste"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Domicile Certificate -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docDomicile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Passport Photo -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docPhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Bank Passbook -->
        <include layout="@layout/item_doc_upload"
            android:id="@+id/docBankPassbook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
